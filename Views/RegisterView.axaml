<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TadidyVeGame.ViewModels"
             x:Class="TadidyVeGame.Views.RegisterView"
             x:DataType="vm:RegisterViewModel"
             Background="#1a1a1a">
    <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*">
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Spacing="20">
            <!-- Title -->
            <TextBlock Text="TADIDY VE" FontSize="48" FontWeight="Bold" Foreground="#3498db" HorizontalAlignment="Center"/>
            <TextBlock Text="Créer un compte" FontSize="24" Foreground="#ecf0f1" HorizontalAlignment="Center"/>

            <!-- Form -->
            <Border Background="#2c3e50" CornerRadius="12" Padding="30" Margin="0,20,0,0">
                <StackPanel Spacing="20">
                    <!-- Username -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Nom d'utilisateur" Foreground="#bdc3c7" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Username}" 
                                 Background="#34495e" Foreground="#ecf0f1" 
                                 Padding="12" CornerRadius="6" Height="40" FontSize="14"
                                 BorderBrush="#3498db" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mot de passe" Foreground="#bdc3c7" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Password}" 
                                 Background="#34495e" Foreground="#ecf0f1" 
                                 Padding="12" CornerRadius="6" Height="40" FontSize="14"
                                 BorderBrush="#3498db" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Confirm Password -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Confirmer mot de passe" Foreground="#bdc3c7" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ConfirmPassword}" 
                                 Background="#34495e" Foreground="#ecf0f1" 
                                 Padding="12" CornerRadius="6" Height="40" FontSize="14"
                                 BorderBrush="#3498db" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#e74c3c" FontSize="12" 
                               TextWrapping="Wrap" IsVisible="{Binding HasError}"/>

                    <!-- Success Message -->
                    <TextBlock Text="{Binding SuccessMessage}" 
                               Foreground="#2ecc71" FontSize="12" 
                               TextWrapping="Wrap" IsVisible="{Binding HasSuccess}"/>

                    <!-- Register Button -->
                    <Button Content="S'inscrire" 
                            Background="#2ecc71" Foreground="White" 
                            Height="45" FontSize="16" FontWeight="Bold" CornerRadius="6"
                            Command="{Binding RegisterCommand}" 
                            IsEnabled="{Binding !IsLoading}"
                            Margin="0,10,0,0"/>

                    <!-- Back to Login -->
                    <StackPanel Spacing="10" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Déjà inscrit ?" Foreground="#bdc3c7" FontSize="12"/>
                        <Button Content="Se connecter" Background="Transparent" 
                                Foreground="#3498db" Padding="0"
                                Command="{Binding BackToLoginCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>