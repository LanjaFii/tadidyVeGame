<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TadidyVeGame.ViewModels"
             x:Class="TadidyVeGame.Views.MyScoresView"
             x:DataType="vm:MyScoresViewModel">
    <Grid Background="#2c3e50" ShowGridLines="False">
        <StackPanel Spacing="20" Margin="20">
            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Top">
                <TextBlock Text="📊 MES SCORES" FontSize="28" FontWeight="Bold" Foreground="#3498db" VerticalAlignment="Center"/>
                <Button Content="Retour" Background="#95a5a6" Foreground="White" 
                        Height="40" Padding="20,0" FontWeight="Bold" CornerRadius="4"
                        Command="{Binding BackCommand}" HorizontalAlignment="Right"/>
            </StackPanel>
            
            <Border Background="#34495e" CornerRadius="8" Padding="15">
                <ListBox ItemsSource="{Binding Scores}" Background="#34495e" Foreground="#ecf0f1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Background="#2c3e50" Margin="0,5" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="14" Foreground="#bdc3c7" Grid.Column="0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5">
                                        <TextBlock Text="{Binding Value}" FontSize="16" FontWeight="Bold" Foreground="#2ecc71"/>
                                        <TextBlock Text="pts" FontSize="12" Foreground="#95a5a6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>