<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TadidyVeGame.Views.GameView">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
        <TextBlock Text="{Binding LevelText}" FontSize="24" HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding TimerText}" FontSize="18" Foreground="Red" HorizontalAlignment="Center"/>
        
        <UniformGrid Rows="3" Columns="3" Width="300" Height="300">
            <Button Name="Btn0" Background="Red" Command="{Binding SquareClickCommand}" CommandParameter="0" Margin="5"/>
            <Button Name="Btn1" Background="Blue" Command="{Binding SquareClickCommand}" CommandParameter="1" Margin="5"/>
            <Button Name="Btn2" Background="Green" Command="{Binding SquareClickCommand}" CommandParameter="2" Margin="5"/>
            <Button Name="Btn3" Background="Yellow" Command="{Binding SquareClickCommand}" CommandParameter="3" Margin="5"/>
            <Button Name="Btn4" Background="Orange" Command="{Binding SquareClickCommand}" CommandParameter="4" Margin="5"/>
            <Button Name="Btn5" Background="Purple" Command="{Binding SquareClickCommand}" CommandParameter="5" Margin="5"/>
            <Button Name="Btn6" Background="Cyan" Command="{Binding SquareClickCommand}" CommandParameter="6" Margin="5"/>
            <Button Name="Btn7" Background="Magenta" Command="{Binding SquareClickCommand}" CommandParameter="7" Margin="5"/>
            <Button Name="Btn8" Background="Gray" Command="{Binding SquareClickCommand}" CommandParameter="8" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</UserControl>