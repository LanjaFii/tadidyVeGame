<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TadidyVeGame.ViewModels"
             x:Class="TadidyVeGame.Views.ScoreView"
             x:DataType="vm:ScoreViewModel">
    <Grid Background="#2c3e50" ShowGridLines="False">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Spacing="25">
            <TextBlock Text="{Binding GameOverTitle}" FontSize="40" FontWeight="Black" Foreground="{Binding TitleColor}" HorizontalAlignment="Center"/>
            
            <Border Background="#34495e" CornerRadius="12" Padding="30">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="SCORE FINAL" Foreground="#bdc3c7" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FinalScore}" FontSize="48" FontWeight="Black" Foreground="#2ecc71" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Background="#2c3e50" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Center">
                                <TextBlock Text="Niveau" Foreground="#95a5a6" FontSize="12"/>
                                <TextBlock Text="{Binding LevelReached}" FontSize="24" FontWeight="Bold" Foreground="#3498db"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5" HorizontalAlignment="Center">
                                <TextBlock Text="Temps" Foreground="#95a5a6" FontSize="12"/>
                                <TextBlock Text="{Binding PlayDuration}" FontSize="20" FontWeight="Bold" Foreground="#e67e22"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Button Content="Rejouer" Background="#3498db" Foreground="White" 
                            Height="50" FontSize="16" FontWeight="Bold" CornerRadius="4"
                            Command="{Binding PlayAgainCommand}" Margin="0,10,0,0"/>
                    
                    <Button Content="Menu Principal" Background="#95a5a6" Foreground="White" 
                            Height="45" FontSize="14" FontWeight="Bold" CornerRadius="4"
                            Command="{Binding BackToMenuCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>